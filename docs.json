{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ByteKit",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Core guides",
            "pages": [
              "guides/http-client",
              "guides/async-toolkit",
              "guides/common-recipes",
              "guides/resilience",
              "guides/streaming-and-realtime"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Package reference",
            "pages": [
              "reference/overview",
              "reference/import-paths"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "HTTP",
            "pages": [
              "api-reference/http-client",
              "api-reference/api-client",
              "api-reference/response-validator",
              "api-reference/schema-adapters",
              "api-reference/url-helper"
            ]
          },
          {
            "group": "Resilience",
            "pages": [
              "api-reference/resilience",
              "api-reference/retry-policy",
              "api-reference/circuit-breaker",
              "api-reference/request-cache",
              "api-reference/request-deduplicator",
              "api-reference/rate-limiter",
              "api-reference/error-boundary"
            ]
          },
          {
            "group": "Async",
            "pages": [
              "api-reference/async"
            ]
          },
          {
            "group": "Observability",
            "pages": [
              "api-reference/observability",
              "api-reference/logger",
              "api-reference/profiler"
            ]
          },
          {
            "group": "Helpers",
            "pages": [
              "api-reference/helpers",
              "api-reference/env-manager",
              "api-reference/storage-utils",
              "api-reference/file-upload-helper",
              "api-reference/streaming-helper",
              "api-reference/websocket-helper",
              "api-reference/cache-manager",
              "api-reference/compression-utils",
              "api-reference/crypto-utils",
              "api-reference/diff-utils",
              "api-reference/event-emitter",
              "api-reference/polling-helper",
              "api-reference/url-helper"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/sebamar88/bytekit",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/bytekit",
          "icon": "box"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Issues",
        "href": "https://github.com/sebamar88/bytekit/issues"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/sebamar88/bytekit"
    }
  },
  "contextual": {
